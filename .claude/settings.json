{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "SQLX_OFFLINE": "true"
  },
  "permissions": {
    "allow": [
      "Bash(cargo fmt:*)",
      "Bash(cargo fmt --check)",
      "Bash(cargo clippy:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo sqlx prepare:*)",
      "Bash(cargo sqlx migrate run:*)",
      "Bash(cargo sqlx migrate add:*)",
      "Bash(sqlx migrate:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git mv:*)",
      "Bash(git add:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)"
    ],
    "deny": [
      "Bash(cargo publish:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
